{
  "name": "kopanel",
  "version": "1.0.0",
  "description": "KoPanel - Tauri + Svelte",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "clean:locked": "powershell -ExecutionPolicy Bypass -File ./scripts/clean-locked.ps1",
    "clean:cache": "powershell -ExecutionPolicy Bypass -File ./scripts/clean-locked.ps1 && cd src-tauri && cargo clean && cd ..",
    "tauri:dev": "npm run clean:locked && npm run tauri dev",
    "tauri:build": "npm run clean:locked && npm run tauri build"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.9.0"
  }
}
